<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/textTurnInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Turn Info"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/textBattleStatus"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:text="Battle Log"
        android:background="#EEEEEE"
        android:padding="8dp"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/textStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Status"
        android:layout_marginBottom="20dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <Button
            android:id="@+id/buttonAttack"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Attack" />

        <Button
            android:id="@+id/buttonDefend"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Defend"
            android:layout_marginTop="10dp" />

        <Button
            android:id="@+id/buttonSkill"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Skill"
            android:layout_marginTop="10dp" />
        
        <Button
            android:id="@+id/buttonAdjustTeamEnd"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Adjust Team"
            android:layout_marginTop="20dp"
            android:visibility="gone" />
        <Button
            android:id="@+id/buttonNextOrRetry"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Next"
            android:layout_marginTop="10dp"
            android:visibility="gone" />
    </LinearLayout>

</LinearLayout>