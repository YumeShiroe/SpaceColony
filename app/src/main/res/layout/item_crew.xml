<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:layout_marginBottom="8dp"
    android:background="#DDDDDD">

    <TextView
        android:id="@+id/textCrewName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Crew Name"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textCrewRole"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Role"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/textTrait"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Trait: None"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/textCrewLevel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Level"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/textCrewExperience"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Experience"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/textCrewHealth"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Health"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/textCrewEnergy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Energy"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/textCrewStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Status"
        android:layout_marginTop="4dp" />

    <Button
        android:id="@+id/buttonSelectCrew"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add" />

</LinearLayout>